    elif gameboard[index].position == 31:
        gameboard[index].position = 36

    elif gameboard[index].position == 35:
        gameboard[index].position = 31

    elif gameboard[index].position == 44:
        gameboard[index].position = 47

    elif gameboard[index].position == 47:
        gameboard[index].position = 45

    return gameboard


